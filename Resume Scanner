# LOAD MODEL

print("Loading model...")

model = SentenceTransformer(
    "all-MiniLM-L6-v2"
)

JD_VEC = model.encode(
    JD,
    convert_to_tensor=True
)

print("Model loaded.")

# EXTRACT TEXT

def extract_text(file_storage):

    try:

        file_storage.stream.seek(0)

        text = ""

        with pdfplumber.open(
            file_storage.stream
        ) as pdf:

            for page in pdf.pages:

                page_text = page.extract_text()

                if page_text:

                    text += page_text + "\\n"

        return text.strip()

    except Exception as e:

        print("PDF ERROR:", str(e))

        return ""

# ANALYZE SKILLS

def analyze_skills(resume_text):

    normalized_resume = re.sub(
        r'[^a-zA-Z0-9 ]',
        ' ',
        resume_text.lower()
    )

    matched_skills = []

    missing_skills = []

    for skill in REQUIRED_SKILLS:

        normalized_skill = re.sub(
            r'[^a-zA-Z0-9 ]',
            ' ',
            skill.lower()
        )

        if normalized_skill in normalized_resume:

            matched_skills.append(skill)

        else:

            missing_skills.append(skill)

    return matched_skills, missing_skills


# VERDICT

def verdict(score, matched_count):

    if score >= 55 and matched_count >= 5:

        return "Shortlisted"

    elif score >= 45:

        return "Maybe"

    return "Rejected"

