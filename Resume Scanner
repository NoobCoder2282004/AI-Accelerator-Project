# SCREEN ROUTE

@app.route("/screen", methods=["POST"])
def screen():

    try:

        files = request.files.getlist("resumes")

        if not files:

            return jsonify({
                "error":"No files uploaded"
            })

        results = []

        for f in files:

            try:

                print("Processing:", f.filename)

                text = extract_text(f)

                if not text:

                    results.append({

                        "candidate": f.filename,

                        "score": 0,

                        "verdict": "Rejected",

                        "matched_count": 0,

                        "matched_skills": [],

                        "missing_skills":
                            REQUIRED_SKILLS[:8]

                    })

                    continue

                resume_vec = model.encode(
                    text,
                    convert_to_tensor=True
                )

                similarity = util.cos_sim(
                    JD_VEC,
                    resume_vec
                )

                score = round(
                    float(similarity[0][0]) * 100,
                    1
                )

                matched_skills, missing_skills = \
                    analyze_skills(text)

                results.append({

                    "candidate":
                        os.path.splitext(
                            f.filename
                        )[0],

                    "score": score,

                    "verdict":
                        verdict(
                            score,
                            len(matched_skills)
                        ),

                    "matched_count":
                        len(matched_skills),

                    "matched_skills":
                        matched_skills[:8],

                    "missing_skills":
                        missing_skills[:8]

                })

            except Exception as inner_error:

                print(traceback.format_exc())

        results.sort(
            key=lambda x: x["score"],
            reverse=True
        )

        return jsonify({
            "results": results
        })

    except Exception as e:

        print(traceback.format_exc())

        return jsonify({
            "error": str(e)
        })

